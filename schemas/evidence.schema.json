{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://etfcta.example/schemas/evidence.schema.json",
  "title": "ETFCTA evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_id", "source_id", "location", "evidence_summary", "supports", "status", "admission"],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^EVD-[A-Z0-9-]+$"},
    "source_id": {"type": "string", "pattern": "^SRC-[A-Z0-9-]+$"},
    "location": {"type": "object", "minProperties": 1},
    "evidence_summary": {"type": "string", "minLength": 1},
    "verbatim_excerpt": {"type": "string", "maxLength": 400},
    "supports": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^ECS-[A-Z0-9-]+$"}},
    "status": {"enum": ["direct_source", "corroborating_source", "conflicting", "insufficient", "superseded", "withdrawn", "unknown", "not_applicable"]},
    "admission": {
      "type":"object", "additionalProperties":false,
      "required":["state","protocol_version","history"],
      "properties":{
        "state":{"enum":["candidate","identity_verified","preserved","extracted","admitted","rejected","withdrawn","superseded"]},
        "protocol_version":{"const":"EAP-001-v0.1.0"},
        "history":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["state","recorded_at"],"properties":{"state":{"type":"string"},"recorded_at":{"type":"string","format":"date-time"},"note":{"type":"string"}}}}
      }
    }
  }
}
