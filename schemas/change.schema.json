{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://etfcta.example/schemas/change.schema.json",
  "title": "ETFCTA classification change event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "fund_id", "effective_date", "recorded_at", "recording_mode", "batch_id", "sequence", "memory_record_created_in_site_release", "decision_origin_data_release", "dimension", "previous_value", "new_value", "previous_decision_id", "new_decision_id", "change_type", "trigger", "source_ids", "standard_version"],
  "properties": {
    "event_id": {"type": "string", "pattern": "^CHG-[A-Z0-9-]+$"},
    "fund_id": {"type": "string", "pattern": "^ETFCTA-FUND-[A-Z0-9-]+$"},
    "effective_date": {"type": "string", "format": "date"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "recording_mode": {"enum":["real_time","retrospective_initialization"]},
    "batch_id": {"type":"string","pattern":"^ETFCTA-[A-Z0-9-]+$"},
    "sequence": {"type":"integer","minimum":1},
    "memory_record_created_in_site_release": {"type":"string","pattern":"^\\d+\\.\\d+\\.\\d+$"},
    "decision_origin_data_release": {"type":"string","pattern":"^\\d+\\.\\d+\\.\\d+$"},
    "dimension": {"type": "string", "minLength": 1},
    "previous_value": {"type": ["string", "null"]},
    "new_value": {"type": ["string", "null"]},
    "previous_decision_id":{"type":["string","null"],"pattern":"^DEC-[A-Z0-9-]+$"},
    "new_decision_id":{"type":["string","null"],"pattern":"^DEC-[A-Z0-9-]+$"},
    "change_type": {"enum": ["initial_admission", "fund_changed", "disclosure_changed", "evidence_improved", "rule_changed", "correction"]},
    "trigger": {"type": "string", "minLength": 1},
    "source_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^SRC-[A-Z0-9-]+$"}},
    "standard_version": {"type": "string", "pattern": "^ECS-001-v\\d+\\.\\d+\\.\\d+$"}
    ,"correction_metadata": {
      "type":"object","additionalProperties":false,
      "required":["initiator","detected_at","published_at","public_explanation","downstream_effect","notification_required"],
      "properties":{
        "initiator":{"type":"string","minLength":1},
        "detected_at":{"type":"string","format":"date-time"},
        "published_at":{"type":"string","format":"date-time"},
        "public_explanation":{"type":"string","minLength":1},
        "downstream_effect":{"type":"string","minLength":1},
        "notification_required":{"type":"boolean"}
      }
    }
  }
}
